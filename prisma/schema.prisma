generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id             String      @id
  name           String
  broker         String
  initialBalance Float
  currency       String      @default("USD")
  createdAt      DateTime    @default(now())
  trades         Trade[]
  plans          TradePlan[]
}

model Trade {
  id           String     @id
  date         String
  symbol       String
  underlying   String
  type         String
  direction    String
  optionType   String?
  strike       Float?
  expiry       String?
  quantity     Float
  entryPrice   Float
  exitPrice    Float
  commission   Float
  fees         Float
  pnl          Float
  status       String
  entryTime    String?
  exitTime     String?
  rr           String?
  mae          Float?
  mfe          Float?
  hourOfDay    Int?
  playbookId   String?
  planId       String?
  tags         String     @default("[]")
  journalEntry String?
  link         String?
  imageUrls    String     @default("[]")
  accountId    String?
  account      Account?   @relation(fields: [accountId], references: [id])
  plan         TradePlan?
  createdAt    DateTime   @default(now())
}

model TradePlan {
  id           String   @id
  date         String
  symbol       String
  underlying   String
  direction    String
  setupType    String?
  thesis       String?
  entryZone    String?
  stopLevel    Float?
  targetLevel  Float?
  plannedRR    String?
  plannedSize  Float?
  invalidation String?
  status       String   @default("pending")
  tradeId      String?  @unique
  trade        Trade?   @relation(fields: [tradeId], references: [id])
  accountId    String?
  account      Account? @relation(fields: [accountId], references: [id])
  createdAt    DateTime @default(now())
}

model Playbook {
  id            String   @id
  name          String
  description   String?
  rules         String   @default("[]")
  timeframes    String?
  instruments   String?
  entryTriggers String   @default("[]")
  exitRules     String?
  notes         String?
  imageUrls     String   @default("[]")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model JournalTemplate {
  id        String   @id
  name      String
  content   String
  scope     String   @default("all")
  createdAt DateTime @default(now())
}

model Tag {
  id   String @id
  name String @unique
}
